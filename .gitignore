# =============================================================================
# UrbanPulse — корневой .gitignore
# =============================================================================

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Виртуальные окружения
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.Python

# Дистрибутив / сборка
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheels/
share/python-wheels/
sdist/

# Тесты / покрытие
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Mypy / Pyre
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Celery
celerybeat-schedule

# Прочее Python
*.sage.py
.python-version
local_settings.py
ipython_config.py
profile_default/

# =============================================================================
# Node.js / Frontend
# =============================================================================
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# Next.js
.next/
out/

# Сборка
/build/

# =============================================================================
# Данные и геопространственные файлы (тяжёлые, не для репо)
# =============================================================================
*.pbf
*.osm
*.osm.bz2
*.osm.gz
*.mbtiles
*.gpkg
*.shp
*.shx
*.dbf
*.prj
*.sbn
*.sbx

# Тайлы
seed_tiles/tiles/*
run_loader/data/*
run_loader/custom_files/*

# Исключения — нужные конфиги внутри data/
!run_loader/data/supported_cities.json
!run_loader/data/dem_intermediate/*.ramp

# DEM / растровые данные
*.tif
*.tiff
*.img
*.hgt
*.asc

# GeoJSON результаты (генерируются, не хранятся в репо)
output/
results/
exports/

# Статусы фаз ETL (локальное состояние)
phase_statuses_file/
*.status

# =============================================================================
# Логи
# =============================================================================
*.log
logs/
src/deploy/mainnginx/access.log
src/deploy/mainnginx/error.log

# =============================================================================
# Переменные окружения и секреты
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.pem
secrets/
credentials.json

# =============================================================================
# Docker
# =============================================================================
# Не игнорируем docker-compose файлы — они нужны в репо
# Игнорируем локальные оверрайды
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# IDE и редакторы
# =============================================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.spyderproject
.spyproject
.ropeproject

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# C# / .NET (для будущих сервисов)
# =============================================================================
bin/
obj/
*.user
*.suo
.vs/
*.nupkg
*.snupkg
packages/
TestResults/
*.coverage
*.coveragexml

# =============================================================================
# Документация проекта (локальная)
# =============================================================================
PLAN.md

# =============================================================================
# Временные файлы
# =============================================================================
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

*.vscode